@page "/ComprasAnticipadasPendientes"
@using PortalDePedidosModel
@using PortalDePedidosService
@using PortalDePedidosShared.ComprasAnticipadasPendientesVM
@using PortalDePedidosShared.IngresoPedidosVM
@using PortalDePedidosShared.UsuariosVM
@using Blazorise.DataGrid
@using Blazorise
@using Blazored.SessionStorage
@using PortalDePedidos.Extensiones
@using ClosedXML.Excel
@inject DataWareHouseClienteService _dataWarehouseService
@inject UsuarioClienteService _usuarioService
@inject IJSRuntime JSRuntime
@inject ExcelService _excelService
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.WebUtilities
@inject ISessionStorageService _sessionStorageService;
@inject ComprasAnticipadasPendientesContainer _comprasAnticipadasPendientesContainer
@inject CarritoPedidosContainer _carritoPedidos
@inject NavigationManager navigation

<div class="my-scrollbar-page">
<div class="card card-primary mt-2">
    <div class="card-header">
        @if (_comprasAnticipadasPendientesContainer?.cliente != null && sesionUsuario.Rol == "Comercial")
        {
                <h3 class="card-title">Saldos de ventas anticipadas de cliente: @_comprasAnticipadasPendientesContainer.cliente.nombreUsuario</h3>
        }
        else if (sesionUsuario != null && sesionUsuario.Rol != "Comercial")
        {
                <h3 class="card-title">Saldos de ventas anticipadas de cliente: @sesionUsuario.NombreUsuario</h3>
        }
    </div>

    <div class="card-body">
        <EditForm Model="filtro" OnInvalidSubmit="Buscar">

            <div class="input-group row">
                <label class="col-1">Fecha Desde: </label>
                <div class="col-2">
                    <InputDate class="form-control" @bind-Value="@filtro.FechaDesde" disabled="@espera"></InputDate>
                    <ValidationMessage For="(()=> filtro.FechaDesde)" />
                </div>

                <label class="col-1">Fecha Hasta: </label>
                <div class="col-2">
                    <InputDate class="form-control" @bind-Value="@filtro.FechaHasta" disabled="@espera"></InputDate>
                    <ValidationMessage For="(()=> filtro.FechaHasta)" />
                </div>
                
            </div>

            <div class="input-group row mt-2">
                <label class="col-1">Cliente: </label>
                <div class="col-2">
                    <InputSelect class="form-control" @bind-Value="@filtro.CodCliente" disabled>
                        @if (sesionUsuario?.Rol != "Comercial")
                        {
                            <option value="@sesionUsuario?.NroUsuarioJDE">@sesionUsuario?.NroUsuarioJDE - @sesionUsuario?.NombreUsuario</option>
                        }
                        else if (_comprasAnticipadasPendientesContainer?.cliente != null)
                        {
                            <option value="@_comprasAnticipadasPendientesContainer.cliente.nroUsuarioJDE">@_comprasAnticipadasPendientesContainer.cliente.nroUsuarioJDE - @_comprasAnticipadasPendientesContainer.cliente.nombreUsuario</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="(()=> filtro.CodCliente)" />
                </div>

                <label class="col-1">Artículo: </label>
                <div class="col-2">
                        <InputText class="form-control" @bind-Value="@filtro.Articulo" placeholder="Código o Descripción" disabled="@espera"></InputText>
                </div>

                <div class="input-group-append col-1">
                    <button class="btn" @onclick="Buscar" disabled="@espera">
                        <i class="fas fa-search fa-fw"></i>
                    </button>
                </div>
                <div class="col-3"></div>
                @if (sesionUsuario.Rol == "Comercial")
                {
                    <div class="input-group-append col-2">
                        <button class="btn btn-primary" @onclick="Recargar">
                            <i class="fas fa-user"></i> Consultar otro cliente
                        </button>
                    </div>
                }
            </div>
        </EditForm>
    </div>

</div>


    @* Informacion importante *@
    <div id="alerta" class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle " style="color:whitesmoke"></i>
        Estos registros se actualizan cada tres horas. Si aún no ve alistada su orden, reintente más tarde.
        <button type="button" class="close" data-bs-dismiss="alert" aria-label="Close">
            <span style="color:white">&times;</span>
        </button>
    </div>

    <div id="alerta1" class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle " style="color:whitesmoke"></i>
        CONSIDERACIONES: No se permite elegir filas de distintas SH o filas sin Cantidad Pendiente. El Pallet Retornable no se elige (el sistema lo agrega luego automáticamente)
        <button type="button" class="close" data-bs-dismiss="alert" aria-label="Close">
            <span style="color:white">&times;</span>
        </button>
    </div>

<div class="card">
    <div class="card-body">
        @if (espera)
        {

            <div style="display:flex;align-items:center;justify-content:center">
                <div class="spinner-border text-primary" role="status">
                    <span class="sr-only">Loading...</span>
                </div>
            </div>
        }
        else
        {
                <div class="row mb-2">

                    <a class="col col-1" style="align-content:center;" type="Button" @onclick="GenerarExcel">
                        <Tooltip Text="Exportar Excel" Placement="TooltipPlacement.Top">
                            <i class="fas fa-file-excel"></i> Excel
                        </Tooltip>
                    </a>

                    <div class="col col-9"></div>
                    @if (sesionUsuario.Rol == "Comercial")
                    {

                        <div class=" col col-2">
                            <button class="btn btn-primary m-1" @onclick="GenerarSG" disabled="@espera">
                                <i class="fas fa-shopping-cart"></i> Generar SG
                            </button>
                        </div>
                    }
                </div>
             <DataGrid TItem="ComprasAnticipadasVM"
                      Data="@comprasAnticipadasPendientes"
                      PageSize="10000"
                      Responsive
                      Class="table table-bordered table-striped">

                    @if (sesionUsuario.Rol == "Comercial")
                    {

                        <DataGridColumn Field="" Caption="" Editable="false">
                            <DisplayTemplate>

                                @if ((comprasAnticipadasPendientes.Where(x => x.Seleccionado).ToList().Count == 0
                                                        || comprasAnticipadasPendientes.Where(x => x.Seleccionado).ToList().Exists(x => x.NroDoc == context.NroDoc))
                                                        && context.CodArticulo != "905")
                                {
                                    <input style="width: 10px;height: 10px;" type="checkbox" class="form-check" @bind="context.Seleccionado" />
                                }
                            </DisplayTemplate>
                        </DataGridColumn>
                    }
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.NroDoc)" Caption="Nro. de Documento - SH" Editable="false"></DataGridColumn>
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.NroFactura)" Caption="Nro. de Factura" Editable="false"></DataGridColumn>
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.NroLinea)" Caption="Nro. de Linea" Editable="false"></DataGridColumn>
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.FechaOrden)" Caption="Fecha" Editable="false"></DataGridColumn>
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.CodArticulo)" Caption="Código de Artículo" Editable="false"></DataGridColumn>
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.Desc1)" Caption="Descripción Artículo" Editable="false"></DataGridColumn>
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.CantPedida)" Caption="Cantidad Pedida" Editable="false"></DataGridColumn>
                    @* <DataGridColumn Field="@nameof(ComprasAnticipadasVM.CantEntregada)" Caption="Cantidad Entregada" Editable="false"></DataGridColumn> *@
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.CantSgSinProcesar)" Caption="Cantidad Pendiente Sin Procesar" Editable="false"></DataGridColumn>
                    <DataGridColumn Field="@nameof(ComprasAnticipadasVM.CantPendiente)" Caption="Cantidad Pendiente" Editable="false"></DataGridColumn>
                
            </DataGrid> 


        }
    </div>
</div>
</div>

@code {
    List<ComprasAnticipadasVM> comprasAnticipadasPendientes = new();
    List<UsuarioVM> clientes = new();
    FiltroComprasAnticipadasPendientes filtro = new();
    public bool espera = false;
    SesionUsuario sesionUsuario = new();

    protected override async Task OnInitializedAsync()
    {
        espera = true;
        sesionUsuario = await _sessionStorageService.ObtenerStorage<SesionUsuario>("sesionUsuario");
        if (sesionUsuario == null)
        {
            await JSRuntime.InvokeVoidAsync("AlertaArticulo", "Error: Usuario no encontrado.");
            return;
        }

        if (_comprasAnticipadasPendientesContainer.cliente == null && sesionUsuario.Rol == "Comercial")
        {
            var msj = "¡Debe seleccionar un cliente antes de consultar sus saldos de ventas anticipadas!";
            await JSRuntime.InvokeVoidAsync("AlertaArticulo", msj);
            navigation.NavigateTo("/ComprasAnticipadasPendientesTablaClientes");
            return;
        }


        //clientes = (await _usuarioService.GetClientes()).OrderByDescending(x => x.nroUsuarioJDE).ToList();

        if (sesionUsuario.Rol != "Comercial")
        {
            filtro.CodCliente = int.Parse(sesionUsuario.NroUsuarioJDE);
        }
        else if (_comprasAnticipadasPendientesContainer.cliente != null)
        {
            filtro.CodCliente = int.Parse(_comprasAnticipadasPendientesContainer.cliente.nroUsuarioJDE);
        }

        comprasAnticipadasPendientes = await _dataWarehouseService.GetComprasAnticipadasPendientes(filtro);
        espera = false;
    }

    public void GenerarSG()
    {
        _carritoPedidos.IngresoPedidoVM = new();

        var seleccionados = comprasAnticipadasPendientes.Where(x => x.Seleccionado).ToList();

        if (seleccionados.Count == 0)
        {
            JSRuntime.InvokeVoidAsync("AlertaArticulo", "Debe seleccionar al menos un registro para generar la SG.");
            return;
        }

        if(seleccionados.Any(x => x.LlevaPalletRetornable))
        {
            var articuloPallet = seleccionados.Where(x => x.LlevaPalletRetornable).FirstOrDefault();
            seleccionados.Add(comprasAnticipadasPendientes.Where(x => x.CodArticulo == "905" && x.NroDoc == articuloPallet.NroDoc).First());
        }


        _carritoPedidos.IngresoPedidoVM.seleccionadosSG = seleccionados;
        _carritoPedidos.IngresoPedidoVM.EsCompraAnticipada = true;
        navigation.NavigateTo("/IngresoPedidos");

    }


    public async Task Buscar()
    {
        espera = true;
        if (sesionUsuario.Rol != "Comercial")
        {
            filtro.CodCliente = int.Parse(sesionUsuario.NroUsuarioJDE);
        }
        comprasAnticipadasPendientes = await _dataWarehouseService.GetComprasAnticipadasPendientes(filtro);
        espera = false;
    }
    private async Task downloadFile(string fileName, string filePath)
    {
        var element = await JSRuntime.InvokeAsync<IJSObjectReference>("BlazorDownloadFile", "a");
        await element.InvokeVoidAsync("setAttribute", "href", filePath);
        await element.InvokeVoidAsync("setAttribute", "download", fileName);
        await element.InvokeVoidAsync("click");
        await element.InvokeVoidAsync("dispose");
    }

    private async Task Recargar()
    {
        _comprasAnticipadasPendientesContainer.cliente = null;
        navigation.NavigateTo("/ComprasAnticipadasPendientesTablaClientes");
    }

    private async Task GenerarExcel()
    {
        await _excelService.exportExcelComprasAnticipadasPendientes(comprasAnticipadasPendientes, filtro, JSRuntime, _comprasAnticipadasPendientesContainer.cliente);
    }
}

<script>
    function BlazorDownloadFile(filename, bytesBase64) {
        var link = document.createElement('a');
        link.download = filename;
        link.href = "data:application/octet-stream;base64," + bytesBase64;
        document.body.appendChild(link); // Needed for Firefox
        link.click();
        document.body.removeChild(link);
    }

</script>
