            navigation.NavigateTo("/CuentasCorrientesTablaUsuarios");
            return;
        }

        espera = true;
        clientes = (await _usuarioService.GetClientes()).OrderByDescending(x => x.nroUsuarioJDE).ToList();

        if (sesionUsuario.Rol != "Comercial")
        {
            filtro.NroCliente = int.Parse(sesionUsuario.NroUsuarioJDE);
        }
        else if (_cuentasCorrientesContainer.cliente != null)
        {
            filtro.NroCliente = int.Parse(_cuentasCorrientesContainer.cliente.nroUsuarioJDE);
        }
        await Buscar();

        espera = false;
    }



