@page "/FinDePedido"
 @using Microsoft.AspNetCore.Authorization
 @using System.Security.Claims;
 @using Blazored.SessionStorage;
 @using PortalDePedidosModel;
 @using PortalDePedidos;
@using PortalDePedidosService
@using PortalDePedidosShared.AuditoriasVM
@using PortalDePedidosShared.DataWhereHouse
 @using PortalDePedidosShared.UsuariosVM;
 @using PortalDePedidosShared.IngresoPedidosVM;
 @using PortalDePedidos.Extensiones;
 @using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject ISessionStorageService _sessionStorageService
@inject IJSRuntime js
@inject PdfClienteService _pdfService
@inject CarritoPedidosContainer _carritoPedidos
@inject UsuarioClienteService _usuarioService
@inject IngresoPedidoClienteService _ingresoPedidoService
@inject NavigationManager navigation
@inject AuditoriaClienteService _auditoriaService
@inject AppSettings _appSettings

<div class="my-scrollbar-page">
    <div class="card card-primary mt-2">

        <div class="card-header">
            
            <h3 class="card-title">Fin de pedido</h3>
            
        </div>

        <div class="card-body">
            <button class="btn btn-primary" @onclick="ExportToPdf">Exportar a PDF</button>
            <div id="infoPedido" class="container">
                <div class="row">
                    <!-- Logo -->
                    <div class="col">
                        <img src="data:image/png;base64," alt="Logo de PCR" width="150" style="display: block; margin: 0 auto;">
                    </div>
                    <!-- Fecha y hora -->
                    <div class="col" style="text-align: right; font-family: Arial, sans-serif; font-size: 14px; color: #555;">
                        <p style="margin: 0;"><strong>@time</strong></p>
                    </div>

                </div>
                <div class="row" style="text-align:center">
                    <h3>Se realizo correctamente el pedido </h3>
                </div>
                <div class="row">
                    <div class="col">
                        <p class="card-text">Cliente: @_carritoPedidos.InformacionFinalPedido.cliente.razonSocial</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col">
                        <p class="card-text">Retiro: @RetiroManager.GetDescripcion(_carritoPedidos.retiroEn)</p>
                    </div>
                </div>



                @if (_carritoPedidos.InformacionFinalPedido.cantidadPalletRetornables > 0)
                {
                    <div class="row">
                        <div class="col">
                            <p class="card-text">Pallets retornables: @_carritoPedidos.InformacionFinalPedido.cantidadPalletRetornables</p>
                        </div>
                    </div>
                }

                <div class="row">
                    <div class="col-2">
                        <p class="card-text">Artículos en el pedido:</p>
                    </div>
                    <div class="col-10"></div>
                </div>

                <div class="row mt-3" style="text-align:center">
                    
                    <table style="width: 100%;
                                max-width: 100%;
                                margin-bottom: 1rem;
                                background-color: transparent;
                                border-collapse: collapse;
                                border: 1px solid #dee2e6;">

                        <thead>
                            <tr>
                                <th style="border: 1px solid #dee2e6;">Código</th>
                                <th style="border: 1px solid #dee2e6;">Descripción</th>
                                <th style="border: 1px solid #dee2e6;">Cantidad</th>
                                <th style="border: 1px solid #dee2e6;">Unidades</th>
                                <th style="border: 1px solid #dee2e6;">Peso</th>
                            </tr>
                        </thead>
                        <tbody style="border-top: 2px solid #dee2e6;">
                            @foreach (var item in _carritoPedidos.InformacionFinalPedido.articulos)
                            {
                                <tr>
                                    <td style="border: 1px solid #dee2e6;">@item.CodArticulo</td>
                                    <td style="border: 1px solid #dee2e6;">@item.Descripcion</td>
                                    <td style="border: 1px solid #dee2e6;">@item.Cantidad @item.UnidadDeMedida</td>
                                    <td style="border: 1px solid #dee2e6;">@item.unidadesTotales</td>
                                    <td style="border: 1px solid #dee2e6;">@Math.Round(item.CalcularTN(), 2) TN</td>
                                </tr>
                            }


                        </tbody>
                    </table>
                </div>

                <div class="row">
                    <div class="col-2">
                        <p class="card-text">Pedidos similares:</p>
                    </div>
                    <div class="col-10"></div>
                </div>

                <div class="row mt-3" style="text-align:center">

                    <table style="width: 100%;
                                max-width: 100%;
                                margin-bottom: 1rem;
                                background-color: transparent;
                                border-collapse: collapse;
                                border: 1px solid #dee2e6;">

                        <thead>
                            <tr>
                                <th style="border: 1px solid #dee2e6;">Nro. de pedido</th>
                                <th style="border: 1px solid #dee2e6;">Fecha de entrega</th>
                                <th style="border: 1px solid #dee2e6;">Observaciones</th>
                            </tr>
                        </thead>
                        <tbody style="border-top: 2px solid #dee2e6;">
                            @foreach (var item in _carritoPedidos.InformacionFinalPedido.pedidos)
                            {
                                <tr>
                                    <td style="border: 1px solid #dee2e6;">@item.IdPedido</td>
                                    <td style="border: 1px solid #dee2e6;">@item.fechaDeEntrega.ToString("dd/MM/yyyy")</td>
                                    <td style="border: 1px solid #dee2e6;">@item.observaciones</td>
                                </tr>
                            }


                        </tbody>
                    </table>
                </div>

                <div class="row">
                    <div class="col-2">
                        <p class="card-text">Peso Total: @Math.Round(_carritoPedidos.InformacionFinalPedido.pesoTotal, 2) TN</p>
                    </div>
                    <div class="col-10"></div>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    private string time;

    protected override async Task OnInitializedAsync() {
        // Establece la fecha y hora actual
        time = DateTime.Now.ToString("dd/MM/yyyy HH:mm") ?? "Fecha no disponible";
    }

    private async Task ExportToPdf() {
        // Obtiene el contenido HTML de la vista previa
        var infoHtml = await js.InvokeAsync<string>("getInfoHtml","#infoPedido");

        try {
            // Generar el PDF con el HTML procesado
            var pdfBytes = await _pdfService.GetPdfByte(infoHtml);
            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"Pedido_{_carritoPedidos.InformacionFinalPedido.idPedido}.pdf";

            // Descargar el PDF generado
            await js.InvokeVoidAsync("BlazorDownloadFile",fileName,base64);
        } catch(Exception ex) {
            Console.WriteLine($"Error al exportar a PDF: {ex.Message}");
        }
    }
}

<script>
    function BlazorDownloadFile(filename, bytesBase64) {
        var link = document.createElement('a');
        link.download = filename;
        link.href = "data:application/octet-stream;base64," + bytesBase64;
        document.body.appendChild(link); // Needed for Firefox
        link.click();
        document.body.removeChild(link);
    }

    function getInfoHtml(selector) {
        return document.querySelector(selector).outerHTML;
    }
</script>